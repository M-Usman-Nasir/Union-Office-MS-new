# =============================================================================
# Frontend environment (Vite) – used when running locally (npm run dev)
# For production, Render uses env vars set in the Render dashboard, not this file.
# =============================================================================

# API base URL the frontend calls. Use local backend when developing locally so
# your code changes hit the local server and the live database.
# For production build on Render, set this in Render's frontend service env to
# your backend API URL (e.g. https://your-backend.onrender.com/api).
VITE_API_URL=http://localhost:1000/api

# Application display name (shown in UI).
VITE_APP_NAME=Homeland Union

# Application version (for display or debugging).
VITE_APP_VERSION=0.1.0

# Google Maps API key for map features (keep secret; do not commit if public repo).
VITE_GOOGLE_MAPS_API_KEY=AIzaSyAOaDH4S6rmAAxVplU8Qc_KfbWVWUxeGxE

# Suppresses SASS deprecation warnings for legacy JS API (build cleanliness).
SASS_SILENCE_DEPRECATIONS=legacy-js-api