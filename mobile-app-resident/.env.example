# Backend API base URL (no trailing slash). Use your machine's LAN IP for physical device testing.
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# For EAS/GitHub builds (production): set EXPO_PUBLIC_API_URL in Expo Dashboard → Project → Secrets
# to your Render backend, e.g. https://YOUR-BACKEND.onrender.com/api (same DB as portals).

# For Android emulator use: http://10.0.2.2:3000/api
# For iOS simulator use: http://localhost:3000/api
# For physical device on same network use: http://192.168.x.x:3000/api
