{
  "expo": {
    "name": "Union Resident",
    "slug": "homeland-union-office-management",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mob_Logo.png",
    "scheme": "unionresident",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-bg.png",
      "resizeMode": "cover",
      "backgroundColor": "#f1f5f9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unionoffice.resident",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/mob_Logo.png",
        "backgroundColor": "#000000"
      },
      "package": "com.unionoffice.resident",
      "permissions": [
        "READ_CONTACTS",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "5dffc3a6-68ef-45fd-964b-b12a20bea300"
      }
    },
    "owner": "usman_nasir"
  }
}
